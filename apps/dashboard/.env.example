# Copy to .env and fill in.

# --- Convex backend ---
# The backend's public client/WebSocket origin (CONVEX_CLOUD_ORIGIN).
# Local self-hosted default:
PUBLIC_CONVEX_URL=http://127.0.0.1:3210
# The backend HTTP-actions origin (auth handler + ingest). Convex serves auth here.
PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# The backend's public HTTP-actions / ingest origin (CONVEX_SITE_ORIGIN). This is
# the host that goes into project DSNs. Local self-hosted default:
PUBLIC_SVELTRY_INGEST_URL=http://127.0.0.1:3211

# --- Better Auth (identity, backed by Postgres) ---
# The dashboard's own public origin. MUST match the Convex `SITE_URL` and is used
# as the JWT issuer.
PUBLIC_APP_URL=http://localhost:5173

# Postgres connection string for the Better Auth `sveltry` database.

# A long random string used to sign sessions. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGE_ME_openssl_rand_hex_32
