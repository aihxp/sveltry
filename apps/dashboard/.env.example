# Copy to .env and fill in.

# --- Convex backend ---
# The backend's public client/WebSocket origin (CONVEX_CLOUD_ORIGIN).
# Local self-hosted default:
PUBLIC_CONVEX_URL=http://127.0.0.1:3210
# The backend HTTP-actions origin. Convex serves auth (/api/auth/*) here, and the
# SvelteKit app proxies to it. Also the host that goes into project DSNs.
PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211
PUBLIC_SVELTRY_INGEST_URL=http://127.0.0.1:3211

# --- Auth (Better Auth on Convex, no Postgres) ---
# The dashboard's own public origin. MUST equal the Convex deployment's `SITE_URL`
# (Better Auth's trusted-origin check), or sign-in fails with "Invalid origin".
PUBLIC_APP_URL=http://localhost:5173
