{
  "name": "@sveltry/dashboard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Sveltry's SvelteKit dashboard: live issue stream, triage, projects, and alerts.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
