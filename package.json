{
  "name": "sveltry",
  "version": "0.7.0",
  "private": true,
  "description": "The reactive, self-hosted, Sentry-compatible error tracker built for the modern web.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^5.9.0",
      "svelte": "^5.56.0",
      "@sveltejs/kit": "^2.65.0",
      "@sveltejs/vite-plugin-svelte": "^6.0.0",
      "vite": "^8.0.0",
      "convex": "^1.41.0",
      "convex-svelte": "^0.13.0",
      "convex-helpers": "^0.1.110",
      "better-auth": "^1.6.18",
      "pg": "^8.13.0",
      "jose": "^6.0.0",
      "zod": "^4.0.0",
      "tailwindcss": "^4.3.0",
      "@tailwindcss/vite": "^4.3.0",
      "tw-animate-css": "^1.4.0",
      "tailwind-variants": "^3.2.0",
      "tailwind-merge": "^3.0.0",
      "clsx": "^2.1.1",
      "bits-ui": "^2.18.0",
      "mode-watcher": "^1.1.0",
      "@lucide/svelte": "^1.18.0",
      "@tanstack/table-core": "^8.21.0"
    },
    "catalogs": {
      "testing": {
        "vitest": "^3.0.0",
        "@sentry/sveltekit": "^10.57.0"
      }
    }
  },
  "scripts": {
    "build": "bun run --filter '*' --if-present build",
    "dev": "bun run --parallel --filter '*' --if-present dev",
    "dev:dashboard": "bun run --filter '@sveltry/dashboard' dev",
    "dev:backend": "bun run --filter '@sveltry/backend' dev",
    "test": "bun run --filter '*' --if-present test",
    "check": "bun run --filter '*' --if-present check",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "infra:up": "docker compose --env-file infra/.env -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose --env-file infra/.env -f infra/docker-compose.yml down",
    "infra:logs": "docker compose --env-file infra/.env -f infra/docker-compose.yml logs -f backend",
    "ci:version": "changeset version && bun update",
    "ci:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.31.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.9.3"
  }
}
