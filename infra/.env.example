# Copy to infra/.env and fill in. Used by `docker compose --env-file infra/.env`.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sveltry_dev_password
POSTGRES_PORT=5432

# --- Convex self-hosted backend ---
INSTANCE_NAME=convex-self-hosted
# Generate with: openssl rand -hex 32
INSTANCE_SECRET=CHANGE_ME_openssl_rand_hex_32
BACKEND_PORT=3210
SITE_PROXY_PORT=3211
CONVEX_DASHBOARD_PORT=6791

# Public origins. For local dev these are localhost; in production set them to
# the real public URLs (and put the backend behind TLS via a reverse proxy).
#   CONVEX_CLOUD_ORIGIN -> the client/WebSocket API ( .cloud equivalent )
#   CONVEX_SITE_ORIGIN  -> the HTTP-actions / ingest origin ( .site equivalent )
CONVEX_CLOUD_ORIGIN=http://127.0.0.1:3210
CONVEX_SITE_ORIGIN=http://127.0.0.1:3211

# Local Postgres has no TLS; managed Postgres (Neon/RDS) does, so unset this there.
DO_NOT_REQUIRE_SSL=1
DISABLE_BEACON=true
DISABLE_METRICS_ENDPOINT=true
RUST_LOG=info

# --- Sveltry dashboard (only the Docker `--profile app` path reads these) ---
# The dashboard's public origin. MUST equal the Convex deployment's `SITE_URL`
# (Better Auth's trusted-origin check). Auth runs on Convex (no Postgres for the
# app), so after deploy also run (once):
#   cd apps/backend && bunx convex env set SITE_URL http://localhost:3000
#   cd apps/backend && bunx convex env set CONVEX_INTERNAL_SITE_URL http://localhost:3211
PUBLIC_APP_URL=http://localhost:3000
APP_PORT=3000
